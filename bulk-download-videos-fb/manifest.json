{
  "manifest_version": 3,
  "name": "fbMassDownloader",
  "description": "__MSG_description__",
  "default_locale": "en",
  "version": "0.0.1",
  "minimum_chrome_version": "103",
  "incognito": "not_allowed",
  "version_name": "0.0.1-dev",
  "content_scripts": [
    {
      "js": ["assets/index.ts-loader-Di5VBJYS.js"],
      "matches": ["https://www.facebook.com/*", "https://web.facebook.com/*"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "permissions": ["scripting", "storage", "declarativeNetRequest"],
  "options_page": "src/pages/options/index.html",
  "action": {
    "default_icon": "src/assets/logo/favicon-128.png",
    "default_popup": "src/pages/popup/index.html"
  },
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://web.facebook.com/*"
  ],
  "icons": {
    "16": "src/assets/logo/favicon-16.png",
    "19": "src/assets/logo/favicon-19.png",
    "32": "src/assets/logo/favicon-32.png",
    "38": "src/assets/logo/favicon-38.png",
    "48": "src/assets/logo/favicon-48.png",
    "128": "src/assets/logo/favicon-128.png"
  },
  "web_accessible_resources": [
    {
      "matches": ["https://web.facebook.com/*", "https://www.facebook.com/*"],
      "resources": [
        "*",
        "assets/const-ePAPXCVW.js",
        "assets/index.ts-DoehDKwN.js"
      ],
      "use_dynamic_url": false
    }
  ]
}

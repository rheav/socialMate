---
/**
 * LogoMark — the socialWarmer flame droplet (blue→cyan mark). Rendered from
 * the shared /logo.png so the marketing site, favicon, and extension all use
 * the exact same artwork. `size` controls px width/height.
 */
interface Props {
  size?: number;
  class?: string;
}
const { size = 28, class: className = "" } = Astro.props;
---

<img
  src="/logo.png"
  alt=""
  width={size}
  height={size}
  class={className}
  style={`width:${size}px;height:${size}px;object-fit:contain;`}
  decoding="async"
  aria-hidden="true"
/>

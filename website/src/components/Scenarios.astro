---
/* The cold-account story — a quiet timeline of a profile going invisible.
   Accent dots ramp cool→warm to foreshadow the fix. */
const scenarios = [
  { time: "Day 0", text: "You spin up a fresh page for a new project.", accent: "#80868b" },
  { time: "Day 7", text: "You post — and nobody sees it.", accent: "#a3b3c9" },
  { time: "Day 18", text: "All posting, no browsing. The algorithm reads it as a bot.", accent: "#c9b49a" },
  { time: "Day 30", text: "Reach gets throttled; hashtags stop surfacing you.", accent: "#ffce9e" },
  { time: "Day 45", text: "The account is a ghost town — every post lands on deaf ears.", accent: "#f59e3c" },
  { time: "Tomorrow", text: "It could just warm itself up, one honest scroll at a time.", accent: "#3c7cfc" },
];
---

<section id="scenarios" class="relative overflow-x-clip px-6 py-14 md:py-20">
  <div
    class="mx-auto grid max-w-6xl items-start gap-12 md:grid-cols-[1.2fr_1fr] md:gap-20"
  >
    <!-- Cards (left) -->
    <ol
      class="reveal-group order-2 grid grid-cols-1 gap-4 sm:grid-cols-2 md:order-1 md:gap-5"
    >
      {
        scenarios.map((s, i) => (
          <li
            class="reveal group relative flex min-h-[160px] flex-col justify-between rounded-[1.75rem] border border-stone-100 bg-white p-5 shadow-soft transition-transform duration-500 hover:-translate-y-0.5"
            style={`--stagger: ${i * 60}ms;`}
          >
            <div class="flex items-center gap-2">
              <span
                class="block h-2 w-2 rounded-full"
                style={`background-color: ${s.accent};`}
              />
              <span class="text-sm font-medium text-stone-500">{s.time}</span>
            </div>
            <p
              class="mt-4 text-base leading-snug text-stone-800 transition-colors duration-500 group-hover:text-[color:var(--accent)] md:text-lg"
              style={`--accent: ${s.accent};`}
            >
              {s.text}
            </p>
          </li>
        ))
      }
    </ol>

    <!-- Heading (right, sticky on desktop) -->
    <div
      class="reveal-group order-1 md:order-2 md:sticky md:top-32 md:self-start md:text-left"
    >
      <span
        class="reveal text-xs font-medium tracking-widest text-stone-500 uppercase"
      >
        Why accounts go cold
      </span>
      <h2 class="reveal mt-3 text-3xl font-medium tracking-tight md:text-5xl">
        A silent account is an
        <span
          class="accent-word text-[1.1em] leading-none"
        >invisible</span>
        account.
      </h2>
      <p class="reveal text-muted mt-5 max-w-md text-base md:text-lg">
        Platforms trust profiles that behave like people: they scroll, they
        watch, they react. An account that only posts — or does nothing at
        all — gets scored as fake, throttled, and buried, right when you need
        its content to reach somebody.
      </p>

      <p
        class="reveal mt-10 hidden text-2xl leading-none font-medium text-stone-500 italic md:block"
      >
        — let's keep it warm.
      </p>
    </div>
  </div>
</section>

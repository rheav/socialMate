---
import { Plus } from "@lucide/astro";

const faqs = [
  {
    q: "Is this just a bot?",
    a: "No — it's closer to a very patient assistant. You open the side panel, pick a platform, a mode, and a target, and press Start yourself. The run scrolls, watches videos, and engages at a human pace with random gaps, and every single action is printed to a live log while you watch. Nothing runs on a schedule or behind your back.",
  },
  {
    q: "Will it get my account banned?",
    a: "socialWarmer is built to look indistinguishable from a person browsing: it watches videos before acting, engages on only a fraction of posts (the persona dice), caps consecutive likes with cooldowns, and spaces everything with randomized delays you control. That said, automating any interaction touches the platforms' terms of service — use it on accounts you own, keep targets modest, and treat it as a warming tool, not an engagement farm.",
  },
  {
    q: "Which platforms does it support?",
    a: "Facebook (Reels, the home feed, and keyword/hashtag search), Instagram (Reels and explore/hashtag grids), and TikTok (For You and search). You pick the platform and mode in the side panel; the extension navigates to the right surface by itself.",
  },
  {
    q: "What are personas?",
    a: "Behavior profiles that decide how chatty your engagement is. A Binge Watcher mostly just watches (15% like chance), a Casual Scroller reacts now and then (35%), an Engaged User reacts often (60%). Each persona also gates how many posts get any action at all, so most of a run is honest browsing — exactly like a real session.",
  },
  {
    q: "What's the engagement threshold for?",
    a: "Quality control. Set a minimum like or comment count and the extension reads each post's real counters before acting — posts below the bar still get watched and scrolled past, but only proven content earns a like or save. Your account ends up associated with good content, not noise.",
  },
  {
    q: "What about my data?",
    a: "Everything runs locally in your browser. There's no account, no server, and no analytics — run state and settings live in chrome.storage.local. Even video transcription happens on your machine with a local Whisper model, so nothing you browse ever leaves your computer.",
  },
  {
    q: "What are Transcripts, Saved, and Download?",
    a: "Research tools that ride along in the panel. Transcripts runs local Whisper speech-to-text on videos you choose. Saved collects the videos your runs bookmarked. Download bulk-grabs every reel thumbnail from a profile's reels tab — auto-scrolled, named by reel id, filed into a folder named after the page.",
  },
  {
    q: "Is it going to cost money?",
    a: "It's free. No paywalls, no pro tier, nothing to host.",
  },
];
---

<section id="faq" class="relative px-6 py-16 md:py-24">
  <div class="reveal-group mx-auto max-w-2xl text-center">
    <span
      class="reveal text-xs font-medium tracking-widest text-stone-500 uppercase"
    >
      Small questions
    </span>
    <h2 class="reveal mt-3 text-3xl font-medium tracking-tight md:text-5xl">
      The things people
      <span
        class="accent-word text-[1.1em] leading-none"
      >usually</span>
      ask.
    </h2>
  </div>

  <div class="mx-auto mt-12 max-w-2xl space-y-3">
    {
      faqs.map((f) => (
        <details class="faq-item reveal overflow-hidden rounded-2xl border border-stone-100 bg-white">
          <summary class="flex items-center justify-between gap-4 px-6 py-6 text-base font-medium text-ink md:text-lg">
            <span>{f.q}</span>
            <span
              class="faq-icon flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full text-stone-500"
              aria-hidden="true"
            >
              <Plus size={18} stroke-width={1.75} />
            </span>
          </summary>
          <div class="faq-panel">
            <div class="faq-panel-inner">
              <p class="px-6 pb-6 text-sm leading-relaxed text-stone-600 md:text-base">
                {f.a}
              </p>
            </div>
          </div>
        </details>
      ))
    }
  </div>
</section>

<script is:inline>
  /**
   * Smooth open AND close for <details> panels — animate .faq-panel-inner's
   * height from current scrollHeight to/from 0, then commit the `open` attr.
   */
  (function () {
    const items = document.querySelectorAll(".faq-item");
    items.forEach((item) => {
      const summary = item.querySelector("summary");
      const panel = item.querySelector(".faq-panel-inner");
      if (!summary || !panel) return;

      panel.style.overflow = "hidden";
      panel.style.height = item.hasAttribute("open")
        ? panel.scrollHeight + "px"
        : "0px";
      panel.style.transition = "height 420ms cubic-bezier(0.22, 1, 0.36, 1)";

      summary.addEventListener("click", (e) => {
        e.preventDefault();
        const isOpen = item.hasAttribute("open");

        if (isOpen) {
          panel.style.height = panel.scrollHeight + "px";
          panel.getBoundingClientRect();
          requestAnimationFrame(() => {
            panel.style.height = "0px";
          });
          panel.addEventListener("transitionend", function onEnd(ev) {
            if (ev.propertyName !== "height") return;
            item.removeAttribute("open");
            panel.removeEventListener("transitionend", onEnd);
          });
        } else {
          item.setAttribute("open", "");
          panel.style.height = "0px";
          panel.getBoundingClientRect();
          const target = panel.scrollHeight;
          requestAnimationFrame(() => {
            panel.style.height = target + "px";
          });
          panel.addEventListener("transitionend", function onEnd(ev) {
            if (ev.propertyName !== "height") return;
            panel.style.height = "auto";
            panel.removeEventListener("transitionend", onEnd);
          });
        }
      });
    });
  })();
</script>
